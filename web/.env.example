# Pusher (server-side)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Pusher (client-side, exposed to browser)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Redis (auto-injected by Vercel Marketplace's Upstash Redis integration
# with prefix "KV"). Run `vercel env pull .env.local` after connecting the
# integration to populate this.
KV_REDIS_URL=

# Shared bearer token between web, bridge, and remote-agent
# Generate with: openssl rand -hex 32
INTERNAL_TOKEN=
