# Pusher (server-side)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Pusher (client-side, exposed to browser)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Vercel KV (auto-injected when KV is provisioned via Marketplace)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Shared bearer token between web, bridge, and remote-agent
# Generate with: openssl rand -hex 32
INTERNAL_TOKEN=
